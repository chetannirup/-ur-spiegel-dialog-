<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Retail Experience System · Level 4</title>
<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
    background: #0a0a0a;
    color: #ffffff;
    overflow: hidden;
    cursor: default;
}

.slides-container {
    position: relative;
    width: 100vw;
    height: 100vh;
}

.slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 80px;
    opacity: 0;
    transform: translateX(100px);
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
}

.slide.active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: all;
}

.slide.prev {
    opacity: 0;
    transform: translateX(-100px);
}

h1 {
    font-size: 72px;
    font-weight: 700;
    margin-bottom: 30px;
    letter-spacing: -2px;
    background: linear-gradient(135deg, #38bdf8 0%, #818cf8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: slideInUp 1s ease-out;
}

h2 {
    font-size: 56px;
    font-weight: 600;
    margin-bottom: 40px;
    letter-spacing: -1px;
    color: #f1f5f9;
}

p {
    font-size: 24px;
    line-height: 1.8;
    max-width: 800px;
    text-align: center;
    color: #cbd5e1;
}

.highlight {
    color: #38bdf8;
    font-weight: 600;
}

.small {
    font-size: 18px;
    opacity: 0.7;
}

.hero-image {
    width: 100%;
    max-width: 1000px;
    height: auto;
    border-radius: 24px;
    box-shadow: 0 25px 50px -12px rgba(56, 189, 248, 0.25);
    margin-bottom: 40px;
    animation: fadeIn 1.5s ease-out;
}

.progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 4px;
    background: linear-gradient(90deg, #38bdf8 0%, #818cf8 100%);
    transition: width 0.3s ease;
    z-index: 1000;
}

.nav-hint {
    position: fixed;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: #64748b;
    opacity: 0.8;
    display: flex;
    gap: 20px;
    align-items: center;
}

.nav-hint span {
    padding: 8px 16px;
    background: rgba(255,255,255,0.05);
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.1);
}

.slide-number {
    position: fixed;
    top: 40px;
    right: 40px;
    font-size: 16px;
    color: #64748b;
    font-weight: 500;
}

@keyframes slideInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }
    to {
        opacity: 1;
    }
}

.content-wrapper {
    animation: slideInUp 1s ease-out;
}

.bullet-list {
    text-align: left;
    font-size: 28px;
    line-height: 2;
    max-width: 900px;
}

.bullet-list li {
    margin-bottom: 20px;
    list-style: none;
    position: relative;
    padding-left: 40px;
}

.bullet-list li:before {
    content: "→";
    position: absolute;
    left: 0;
    color: #38bdf8;
    font-weight: bold;
}

@media (max-width: 768px) {
    .slide {
        padding: 40px;
    }
    h1 {
        font-size: 48px;
    }
    h2 {
        font-size: 36px;
    }
    p {
        font-size: 18px;
    }
    .bullet-list {
        font-size: 20px;
    }
}
</style>
</head>
<body>

<div class="progress-bar" id="progressBar"></div>
<div class="slide-number" id="slideNumber">1 / 11</div>
<div class="nav-hint">
    <span>← →</span>
    <span>oder klicken</span>
</div>

<div class="slides-container" id="slidesContainer">

<!-- SLIDE 1 - Hero mit Soras Bild -->
<div class="slide active">
    <img src="https://chetannirup.github.io/-ur-spiegel-dialog-/ChatGPT%20Image%2010.%20Apr.%202026,%2022_20_32.png" alt="Retail Experience Vision" class="hero-image">
    <div class="content-wrapper">
        <h1>Retail Experience System</h1>
        <p class="highlight" style="font-size:28px;">Mehr Umsatz durch Kundenerlebnis</p>
    </div>
</div>

<!-- SLIDE 2 -->
<div class="slide">
    <div class="content-wrapper">
        <h2>Ausgangssituation</h2>
        <p style="text-align:left;max-width:900px;">
            <br>
            Kunden kaufen effizient – aber kurz.
            <br><br>
            Verweildauer ist gering.
            <br>
            Potenzial für Zusatzkäufe bleibt ungenutzt.
            <br><br>
            Gleichzeitig entstehen Abschriften in Frischebereichen.
        </p>
    </div>
</div>

<!-- SLIDE 3 -->
<div class="slide">
    <div class="content-wrapper">
        <h2>Beobachtung</h2>
        <p style="font-size:28px;max-width:1000px;">
            Wenn Kunden stehen bleiben, probieren oder ins Gespräch kommen,
            <br>
            bleiben sie länger im Markt.
            <br><br>
            <span class="highlight" style="font-size:32px;">→ und kaufen oft mehr.</span>
        </p>
    </div>
</div>

<!-- SLIDE 4 -->
<div class="slide">
    <div class="content-wrapper">
        <h2>Idee</h2>
        <p style="text-align:left;max-width:900px;">
            Bestehende Ressourcen anders nutzen:
            <br><br>
            <span class="highlight" style="font-size:30px;">Verkostung statt Abschrift</span>
            <br>
            <span class="highlight" style="font-size:30px;">Aufenthalt statt Durchlauf</span>
            <br><br>
            Kleine Impulse statt großer Umbau.
        </p>
    </div>
</div>

<!-- SLIDE 5 -->
<div class="slide">
    <div class="content-wrapper">
        <h2>Umsetzung (Pilot)</h2>
        <ul class="bullet-list">
            <li>Nutzung vorhandener Fläche (z.B. Sitzmöglichkeit außen)</li>
            <li>Nutzung bestehender Verkostungsroutinen</li>
            <li><span class="highlight">kein zusätzlicher Personalaufwand</span></li>
            <li><span class="highlight">kein Umbau notwendig</span></li>
        </ul>
    </div>
</div>

<!-- SLIDE 6 -->
<div class="slide">
    <div class="content-wrapper">
        <h2>Erwartete Wirkung</h2>
        <ul class="bullet-list">
            <li>Längere Verweildauer</li>
            <li>Mehr Kundeninteraktion</li>
            <li>Mehr Spontankäufe</li>
            <li><span class="highlight" style="font-size:32px;">Steigerung des Warenkorbs</span></li>
        </ul>
    </div>
</div>

<!-- SLIDE 7 -->
<div class="slide">
    <div class="content-wrapper">
        <h2>Prinzip</h2>
        <p style="font-size:28px;max-width:1000px;">
            Menschen reagieren auf Aufmerksamkeit und Erlebnis.
            <br><br>
            Ein kleiner Impuls genügt,
            <br>
            um Verhalten messbar zu verändern.
        </p>
    </div>
</div>

<!-- SLIDE 8 -->
<div class="slide">
    <div class="content-wrapper">
        <h2>Vorschlag</h2>
        <p style="font-size:28px;max-width:1000px;">
            Start eines kleinen, kontrollierten Tests im Markt.
            <br><br>
            Beobachtung der Wirkung über einen definierten Zeitraum.
        </p>
    </div>
</div>

<!-- SLIDE 9 -->
<div class="slide">
    <div class="content-wrapper">
        <h2>Ansatz</h2>
        <p class="highlight" style="font-size:36px;line-height:2;">
            Klein starten.
            <br>
            Wirkung messen.
            <br>
            Erfolgreiches ausbauen.
        </p>
    </div>
</div>

<!-- SLIDE 10 - Call to Action -->
<div class="slide">
    <div class="content-wrapper">
        <h2>Nächster Schritt</h2>
        <p style="font-size:28px;max-width:1000px;">
            Gemeinsam einen Testrahmen definieren
            <br>
            und die ersten Wochen begleiten.
            <br><br>
            <span class="highlight">Messbar. Skalierbar. Ohne Risiko.</span>
        </p>
    </div>
</div>

<!-- SLIDE 11 - Danke -->
<div class="slide">
    <div class="content-wrapper">
        <h1 style="font-size:64px;">Danke</h1>
        <p class="small" style="margin-top:40px;">
            Tim · Retail Experience System
            <br>
            Für Ihren Markt · Mit Herz · Im Flow
        </p>
    </div>
</div>

</div>

<script>
let currentSlide = 0;
const slides = document.querySelectorAll('.slide');
const totalSlides = slides.length;
const progressBar = document.getElementById('progressBar');
const slideNumber = document.getElementById('slideNumber');

function updateSlide() {
    slides.forEach((slide, index) => {
        slide.classList.remove('active', 'prev');
        if (index === currentSlide) {
            slide.classList.add('active');
        } else if (index < currentSlide) {
            slide.classList.add('prev');
        }
    });
    
    const progress = ((currentSlide + 1) / totalSlides) * 100;
    progressBar.style.width = progress + '%';
    slideNumber.textContent = `${currentSlide + 1} / ${totalSlides}`;
}

function nextSlide() {
    if (currentSlide < totalSlides - 1) {
        currentSlide++;
        updateSlide();
    }
}

function prevSlide() {
    if (currentSlide > 0) {
        currentSlide--;
        updateSlide();
    }
}

// Keyboard navigation
document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight' || e.key === ' ') {
        nextSlide();
    } else if (e.key === 'ArrowLeft') {
        prevSlide();
    }
});

// Click navigation
document.getElementById('slidesContainer').addEventListener('click', (e) => {
    const clickX = e.clientX;
    const windowWidth = window.innerWidth;
    
    if (clickX > windowWidth / 2) {
        nextSlide();
    } else {
        prevSlide();
    }
});

// Touch swipe for mobile
let touchStartX = 0;
let touchEndX = 0;

document.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
});

document.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
});

function handleSwipe() {
    if (touchStartX - touchEndX > 50) {
        nextSlide();
    }
    if (touchEndX - touchStartX > 50) {
        prevSlide();
    }
}

// Initialize
updateSlide();
</script>

</body>
</html>
